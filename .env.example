# Runtime
NODE_ENV=development
APP_NAME="ERP Sprint Progress System"

# API
API_HOST=127.0.0.1
API_PORT=5000
API_BASE_URL=http://127.0.0.1:5000
TRUST_PROXY_HOPS=0

# Web
WEB_HOST=127.0.0.1
WEB_PORT=3000
WEB_BASE_URL=http://127.0.0.1:3000
VITE_API_PROXY_TARGET=http://127.0.0.1:5000
# Leave VITE_API_BASE_URL unset locally so the Vite proxy handles /api requests.

# Database
# MongoDB Atlas is the primary database.
MONGODB_URI=mongodb+srv://replace_with_user:replace_with_password@replace_with_cluster/itdcc?retryWrites=true&w=majority
MONGODB_DB_NAME=itdcc
MONGODB_AUTO_INDEX=false
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# Auth
AUTH_PROVIDER=local
SESSION_SECRET=replace_with_long_random_secret_at_least_32_chars
COOKIE_NAME=itdcc_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_COOKIE_NAME=itdcc_csrf
CSRF_HEADER_NAME=x-csrf-token
SESSION_TTL_HOURS=8
BCRYPT_SALT_ROUNDS=12
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_RATE_LIMIT_MAX_REQUESTS=20
FORCE_PASSWORD_CHANGE_ON_FIRST_LOGIN=true

# Initial Super Admin seed
# Required together only when creating the first admin through npm run api:seed.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_FULL_NAME="System Administrator"
INITIAL_ADMIN_PASSWORD=replace_with_temporary_password_at_least_12_chars
INITIAL_ADMIN_JOB_TITLE="Super Admin"
INITIAL_ADMIN_DEPARTMENT="IT"
INITIAL_ADMIN_PHONE=

# Development data seed (never use these accounts in production)
# Set unique temporary passwords locally before npm run api:seed:development.
# DEVELOPMENT_IT_MANAGER_PASSWORD=replace_with_temporary_password_at_least_12_chars
# DEVELOPMENT_SUPERVISOR_PASSWORD=replace_with_temporary_password_at_least_12_chars
# DEVELOPMENT_EMPLOYEE_PASSWORD=replace_with_temporary_password_at_least_12_chars

# ERP team user seed
# Use one temporary password for all new ERP team users, or role-specific values.
# Existing ERP team user passwords are preserved when the seed is rerun.
# ERP_TEAM_INITIAL_PASSWORD=replace_with_temporary_password_at_least_12_chars
# ERP_TEAM_IT_MANAGER_INITIAL_PASSWORD=replace_with_temporary_password_at_least_12_chars
# ERP_TEAM_SUPERVISOR_INITIAL_PASSWORD=replace_with_temporary_password_at_least_12_chars
# ERP_TEAM_EMPLOYEE_INITIAL_PASSWORD=replace_with_temporary_password_at_least_12_chars

# Security
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
CORS_ORIGIN=http://127.0.0.1:3000

# Audit
AUDIT_LOG_ENABLED=true
ALLOW_DEVELOPMENT_SEED=false
