{
  "name": "it-department-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "Planning and architecture base for an IT department control system.",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "api:build": "npm run build --workspace @itdcc/api",
    "api:db:check": "npm run db:check --workspace @itdcc/api",
