    "api:db:indexes": "npm run db:indexes --workspace @itdcc/api",
    "api:db:setup": "npm run db:setup --workspace @itdcc/api",
    "api:dev": "npm run dev --workspace @itdcc/api",
    "api:seed": "npm run seed --workspace @itdcc/api",
    "api:seed:development": "npm run seed:development --workspace @itdcc/api",
    "api:seed:erp-team": "npm run seed:erp-team --workspace @itdcc/api",
